/**
 * @file mmmversion.h
 * @brief 自动生成的版本信息头文件 (由 CMake configure_file() 生成)
 *
 * 将版本号维护在 CMake project(VERSION ...) 一处，
 * 通过 configure_file() 生成此头文件供 C++ 代码使用。
 */

#pragma once

/// @brief 项目显示名称
#define MMM_PROJECT_NAME "@MMM_PROJECT_NAME@"

/// @brief 主版本号
#define MMM_VERSION_MAJOR @PROJECT_VERSION_MAJOR@

/// @brief 次版本号
#define MMM_VERSION_MINOR @PROJECT_VERSION_MINOR@

/// @brief 修订版本号
#define MMM_VERSION_PATCH @PROJECT_VERSION_PATCH@

/// @brief 完整版本字符串 (如 "v0.2.0" 或 "v0.2.0-alpha.1")
#define MMM_VERSION_STRING "v@PROJECT_VERSION@@MMM_VERSION_SUFFIX@"

/// @brief 当前编译目标平台 (windows / macos / linux)
#define MMM_PLATFORM "@MMM_PLATFORM@"
